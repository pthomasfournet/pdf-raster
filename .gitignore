# Rust build artifacts
/target/
**/target/
*.rlib
*.rmeta
*.d

# Cargo lock — committed for binaries, not for libs
# Cargo.lock

# ── IDE / editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.iml
*.swp
*.swo
*.swn
*~
.DS_Store
Thumbs.db
.direnv/
.envrc

# ── Environment / secrets ──────────────────────────────────────────────────────
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/

# ── clangd ────────────────────────────────────────────────────────────────────
# .clangd is a tracked project config; compile_commands.json embeds absolute
# paths from the local install (CUDA_PATH, etc.) so it stays per-machine.
compile_commands.json
.cache/

# ── AI assistant / plugin files ────────────────────────────────────────────────
.claude/
.serena/
CLAUDE.md
# Superpowers plugin runtime dirs (plans, memory, etc.)
superpowers/
# Serena MCP memory and cache dirs
.serena/cache/
.serena/memories/
# Any other plugin runtime directories
.aider/
.continue/
.codeium/

# ── Profiling / perf artifacts ─────────────────────────────────────────────────
perf.data
perf.data.old
*.profraw
*.profdata
flamegraph.svg
criterion/
*.perf

# ── Test / benchmark generated output ─────────────────────────────────────────
tests/bench/bins/
tests/bench/bench-results.json
tests/bench/bench-features-results.json

# ── v0.6.0 GPU baseline raw output ────────────────────────────────────────────
bench/v060/*.txt

# ── Stray compiled binaries at repo root ──────────────────────────────────────
/test_*
/bench_*

# ── Test fixtures and golden references ───────────────────────────────────────
# Add your own PDFs locally; do not commit fixture documents to the repo.
tests/fixtures/*.pdf
tests/golden/ref/*.ppm
tests/golden/ref/*.png
tests/bench/bins/
tests/bench/bench-results.json
tests/bench/bench-features-results.json

# ── Git worktrees ─────────────────────────────────────────────────────────────
.worktrees/

# ── Temp / scratch files ──────────────────────────────────────────────────────
*.tmp
*.bak
*.orig
*.log
ROADMAP_INTEL.md

# ── Local audit reports (deferred-finding tracker) ────────────────────────────
# /audit/ holds review findings whose fix is too large for the commit at hand
# but worth not losing.  Stays local; not part of the project's published docs.
/audit/
